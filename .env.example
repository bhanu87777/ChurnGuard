# ─────────────────────────────────────────────────────────────
# ChurnGuard — environment configuration
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection.
# URL-encode any special characters in the password (e.g. # -> %23, @ -> %40).
# DATABASE_URL = pooled connection (runtime). DIRECT_URL = direct (migrations).
# On Neon: DATABASE_URL = the "-pooler" host, DIRECT_URL = the non-pooler host.
# Drop "&channel_binding=require" from Neon strings — keep only ?sslmode=require.
# Locally, set both to the same local Postgres value.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/churnguard?schema=public"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/churnguard?schema=public"

# Auth.js / NextAuth — generate a secret with: openssl rand -base64 32
AUTH_SECRET="change-me"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Claude API key (optional). Enables the real Claude churn scorer (tool use).
# Get one at https://console.anthropic.com. Leave empty to try Gemini next.
ANTHROPIC_API_KEY=""

# Google Gemini API key (optional, FREE — no credit card).
# Get one at https://aistudio.google.com/apikey. Used when ANTHROPIC_API_KEY is
# empty. If BOTH keys are empty, a transparent rule-based heuristic scorer is
# used — so the app always works end-to-end.
GEMINI_API_KEY=""

# Optional: override the scoring model.
# SCORING_MODEL="claude-sonnet-5"      # Claude (when ANTHROPIC_API_KEY is set)
# GEMINI_MODEL="gemini-flash-latest"   # Gemini (when GEMINI_API_KEY is set)

# Resend (optional). Enables alert + weekly-digest emails; all email paths
# no-op gracefully without it. Get a key at https://resend.com.
RESEND_API_KEY=""
# EMAIL_FROM="ChurnGuard <alerts@yourdomain.com>"   # default: onboarding@resend.dev
# APP_URL="https://your-deployment.vercel.app"       # absolute links in emails

# Vercel Cron protection (required for /api/cron/*). Vercel automatically sends
# it as "Authorization: Bearer <CRON_SECRET>" on scheduled invocations.
CRON_SECRET=""
