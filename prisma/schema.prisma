// ChurnGuard data model
// Problem: SaaS teams learn a customer is leaving only when they cancel.
// Solution: track each account's activity, let the Claude API turn that raw
// behavior into a churn-risk score + reason + recommended save action.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled, runtime
  directUrl = env("DIRECT_URL") // direct, migrations / db push
}

// The dashboard operator (customer-success / founder) who logs in.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String // bcrypt hash
  role      Role     @default(ANALYST)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  notes         Note[]
  tasksAssigned Task[]         @relation("TaskAssignee")
  tasksCreated  Task[]         @relation("TaskCreator")
  notifications Notification[]
  auditLogs     AuditLog[]
  alertRules    AlertRule[]
  segments      Segment[]
  apiKeys       ApiKey[]
}

// An account we are monitoring for churn risk.
model Customer {
  id          String             @id @default(cuid())
  name        String
  email       String             @unique // ingestion (/api/ingest) addresses customers by email
  company     String?
  plan        Plan               @default(FREE)
  mrr         Float              @default(0) // monthly recurring revenue, USD
  signupDate  DateTime           @default(now())
  status      CustomerStatus     @default(ACTIVE)
  churnedAt   DateTime? // set when status flips ACTIVE -> CHURNED; powers churn-rate & cohort analytics
  events      ActivityEvent[]
  riskScore   RiskScore?
  riskHistory RiskScoreHistory[]
  tags        CustomerTag[]
  notes       Note[]
  tasks       Task[]
  notifications Notification[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([signupDate])
}

// A raw churn signal: a thing the customer did (or a support ticket they filed).
model ActivityEvent {
  id         String       @id @default(cuid())
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  type       ActivityType
  metadata   Json? // e.g. { feature: "reports", ticketPriority: "high" }
  occurredAt DateTime     @default(now())

  @@index([customerId, occurredAt])
  @@index([type, occurredAt])
}

// The AI verdict for a customer: 0-100 risk, a plain-English reason, a save action.
model RiskScore {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String   @unique
  score      Int // 0 (safe) - 100 (about to churn)
  band       RiskBand
  reason     String   @db.Text // why the model thinks so
  action     String   @db.Text // recommended retention action
  model      String // which Claude model produced this
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// A point-in-time snapshot of a customer's risk, written on every (re)score.
// Powers the "risk over time" trend chart.
model RiskScoreHistory {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  score      Int
  band       RiskBand
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
}

// Who did what. actorEmail is denormalized so the trail survives user deletion.
model AuditLog {
  id         String   @id @default(cuid())
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorId    String?
  actorEmail String?
  action     String // dot-namespaced: "customer.delete", "auth.login", "settings.update", ...
  targetType String? // "Customer" | "User" | "AlertRule" | ...
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([targetType, targetId])
  @@index([actorId, createdAt])
}

// Key-value app settings; heuristic scoring weights live under key "scoring.weights".
model AppSetting {
  key         String   @id
  value       Json
  updatedById String?
  updatedAt   DateTime @updatedAt
}

// A no-AI automation rule: when a condition fires for a customer, notify the team.
model AlertRule {
  id            String            @id @default(cuid())
  name          String
  enabled       Boolean           @default(true)
  conditionType RuleConditionType
  params        Json // shape depends on conditionType; validated in src/lib/rules.ts
  notifyInApp   Boolean           @default(true)
  notifyEmail   Boolean           @default(false)
  cooldownHours Int               @default(24) // per (rule, customer) re-fire suppression
  createdBy     User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  notifications Notification[]

  @@index([enabled, conditionType])
}

// One row per recipient so read/unread is a simple readAt on the row.
model Notification {
  id         String           @id @default(cuid())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  rule       AlertRule?       @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  ruleId     String?
  customer   Customer?        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String?
  type       NotificationType @default(ALERT)
  title      String
  body       String           @db.Text
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, readAt, createdAt])
  @@index([ruleId, customerId, createdAt]) // cooldown lookup
}

model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  color     String        @default("#6366f1")
  customers CustomerTag[]
  createdAt DateTime      @default(now())
}

model CustomerTag {
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId      String
  createdAt  DateTime @default(now())

  @@id([customerId, tagId])
  @@index([tagId])
}

// A saved dashboard filter. definition JSON shape (validated in src/lib/segments.ts):
// { plans?, bands?, statuses?, mrrMin?, mrrMax?, tagIds?, inactiveDays? }
model Segment {
  id          String   @id @default(cuid())
  name        String   @unique
  definition  Json
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Free-form context on a customer, written by the team.
model Note {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId   String?
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId, createdAt])
}

// A retention intervention: outreach we planned/did, and whether it saved the account.
model Task {
  id          String      @id @default(cuid())
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId  String
  title       String
  description String?     @db.Text
  status      TaskStatus  @default(OPEN)
  outcome     TaskOutcome @default(PENDING)
  dueDate     DateTime?
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId  String?
  createdBy   User?       @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([customerId])
  @@index([assigneeId, status])
  @@index([status, dueDate])
}

// Credential for the public event-ingestion endpoint. Only a sha256 hash is
// stored; the plaintext is shown exactly once at creation.
model ApiKey {
  id          String    @id @default(cuid())
  label       String
  keyHash     String    @unique
  prefix      String // "cg_" + first 8 hex chars, display only
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum CustomerStatus {
  ACTIVE
  CHURNED
}

enum ActivityType {
  LOGIN
  FEATURE_USE
  SUPPORT_TICKET
  PAYMENT
  PAYMENT_FAILED
  NPS_RESPONSE
}

enum RiskBand {
  LOW
  MEDIUM
  HIGH
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum TaskStatus {
  OPEN
  DONE
}

enum TaskOutcome {
  PENDING
  SAVED
  CHURNED
}

enum RuleConditionType {
  BAND_BECOMES
  SCORE_CROSSES
  MRR_AT_LEAST
  EVENT_OCCURS
  INACTIVITY_DAYS
}

enum NotificationType {
  ALERT
  DIGEST
  SYSTEM
}
